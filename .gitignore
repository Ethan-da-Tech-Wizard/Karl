# Virtual Environment
venv/

# Downloaded models (large binary files)
data/models/

# Vector DB (regenerate by re-ingesting)
data/vector_db/

# Trace logs and sessions (user data, not source)
data/logs/
data/sessions/

# model_registry.json is SOURCE CONTROLLED — do not ignore it
# active_model.json is written at runtime and committed by upgrade_manager

# Build artifacts
__pycache__/
*.pyc
*.pyd
*.pyo
*.spec

# VS Build Tools installer
vs_buildtools.exe

# Temp/scratch dirs
t/

# IDE
.vscode/
