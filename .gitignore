# Virtual Environment
venv/

# Downloaded models (large binary files)
data/models/

# Vector DB index (regenerate by re-ingesting)
# NOTE: metadata.json and index.faiss are now persisted but are user-specific artifacts
data/vector_db/

# Trace logs and sessions (user data, not source)
data/logs/
data/sessions/

# model_registry.json is SOURCE CONTROLLED — do not ignore it
# Runtime-written state files (never commit)
data/active_model.json
data/active_vision_model.json
data/ui_config.json
data/theme_config.json

# Local scratch datasets (kept on disk, not in source control)
workers.csv
workers.xlsx
*.xlsx

# Training data and fine-tuned adapters (large, user-specific)
data/training/
data/adapters/
data/hf_models/
unsloth_compiled_cache/

# Eval results (run artifacts — reproducible from datasets)
eval/results/

# Build artifacts
__pycache__/
*.pyc
*.pyd
*.pyo
*.spec

# VS Build Tools installer
vs_buildtools.exe

# Temp/scratch dirs
t/

# IDE
.vscode/

# Scratch directory
scratch/

# Build artifacts for VS Code extension
*.vsix
package-lock.json
node_modules/
