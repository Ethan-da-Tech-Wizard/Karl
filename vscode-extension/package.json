{
  "name": "karl",
  "displayName": "Karl",
  "description": "Local Multi-Agent Software Engineering swarm for VS Code, powered by Karl.",
  "version": "1.4.0",
  "publisher": "ethan-da-tech-wizard",
  "license": "MIT",
  "engines": {
    "vscode": "^1.75.0"
  },
  "categories": [
    "Machine Learning",
    "Programming Languages"
  ],
  "activationEvents": [
    "onView:karl.sidebarView",
    "onCommand:karl.openSidebar",
    "onCommand:karl.fixSelection",
    "onCommand:karl.explainSelection",
    "onCommand:karl.generateTests",
    "onCommand:karl.reviewActiveFile",
    "onCommand:karl.askWorkspace",
    "onCommand:karl.ingestActiveFile",
    "onCommand:karl.ingestWorkspaceFolder"
  ],
  "main": "./extension.js",
  "contributes": {
    "commands": [
      {
        "command": "karl.fixSelection",
        "title": "Ask Karl to Refactor Selection",
        "category": "Karl"
      },
      {
        "command": "karl.explainSelection",
        "title": "Explain Selection",
        "category": "Karl"
      },
      {
        "command": "karl.generateTests",
        "title": "Generate Tests for Active File",
        "category": "Karl"
      },
      {
        "command": "karl.reviewActiveFile",
        "title": "Review Active File",
        "category": "Karl"
      },
      {
        "command": "karl.askWorkspace",
        "title": "Ask About Workspace",
        "category": "Karl"
      },
      {
        "command": "karl.ingestActiveFile",
        "title": "Ingest Active File into Knowledge Base",
        "category": "Karl"
      },
      {
        "command": "karl.ingestWorkspaceFolder",
        "title": "Ingest Workspace Folder into Knowledge Base",
        "category": "Karl"
      },
      {
        "command": "karl.openSidebar",
        "title": "Open Karl Panel",
        "category": "Karl"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "command": "karl.fixSelection",
          "when": "editorHasSelection",
          "group": "karl@1"
        },
        {
          "command": "karl.explainSelection",
          "when": "editorHasSelection",
          "group": "karl@2"
        },
        {
          "command": "karl.generateTests",
          "when": "editorTextFocus",
          "group": "karl@3"
        },
        {
          "command": "karl.reviewActiveFile",
          "when": "editorTextFocus",
          "group": "karl@4"
        }
      ],
      "explorer/context": [
        {
          "command": "karl.ingestActiveFile",
          "when": "resourceScheme == file",
          "group": "karl@1"
        },
        {
          "command": "karl.ingestWorkspaceFolder",
          "when": "explorerResourceIsFolder",
          "group": "karl@2"
        },
        {
          "command": "karl.askWorkspace",
          "when": "workspaceFolderCount > 0",
          "group": "karl@3"
        }
      ]
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "karl-swarm",
          "title": "Karl",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "karl-swarm": [
        {
          "type": "webview",
          "id": "karl.sidebarView",
          "name": "Karl Agent Swarm"
        }
      ]
    },
    "configuration": {
      "title": "Karl Settings",
      "properties": {
        "karl.port": {
          "type": "integer",
          "default": 8080,
          "description": "Port of the local Karl WebSocket server."
        },
        "karl.autoConnect": {
          "type": "boolean",
          "default": true,
          "description": "Automatically connect to the Karl server when the sidebar is opened."
        }
      }
    }
  }
}
