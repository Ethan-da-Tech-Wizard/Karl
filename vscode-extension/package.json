{
  "name": "karl",
  "displayName": "Karl",
  "description": "Local Multi-Agent Software Engineering swarm for VS Code, powered by Karl.",
  "version": "1.1.0",
  "publisher": "ethan-da-tech-wizard",
  "license": "MIT",
  "engines": {
    "vscode": "^1.75.0"
  },
  "categories": [
    "Machine Learning",
    "Programming Languages"
  ],
  "activationEvents": [],
  "main": "./extension.js",
  "contributes": {
    "commands": [
      {
        "command": "karl.fixSelection",
        "title": "Ask Karl to Refactor Selection",
        "category": "Karl"
      },
      {
        "command": "karl.openSidebar",
        "title": "Open Karl Panel",
        "category": "Karl"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "command": "karl.fixSelection",
          "when": "editorHasSelection",
          "group": "karl@1"
        }
      ]
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "karl-swarm",
          "title": "Karl",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "karl-swarm": [
        {
          "type": "webview",
          "id": "karl.sidebarView",
          "name": "Karl Agent Swarm"
        }
      ]
    },
    "configuration": {
      "title": "Karl Settings",
      "properties": {
        "karl.port": {
          "type": "integer",
          "default": 8080,
          "description": "Port of the local Karl WebSocket server."
        },
        "karl.autoConnect": {
          "type": "boolean",
          "default": true,
          "description": "Automatically connect to the Karl server when the sidebar is opened."
        }
      }
    }
  }
}
